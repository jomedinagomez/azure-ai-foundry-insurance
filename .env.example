# Repo-wide local config. Copy to .env and fill in. Do not commit real values.
# Used by the workshop API (apps/workshop/api/standalone_api.py) and by the
# demo/sov, demo/sec, and demo/pro notebooks. Frontend env lives in
# apps/workshop/web/.env (see apps/workshop/web/.env.example).

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — Azure AI Foundry / Cognitive Services endpoint hosting
# Content Understanding (and the chat-completion deployments below).
# Example: https://my-foundry.services.ai.azure.com/
# Aliases also accepted (first non-empty wins, in this order):
#   APP_CONTENT_UNDERSTANDING_ENDPOINT → CONTENTUNDERSTANDING_ENDPOINT → FOUNDRY_ENDPOINT
# ─────────────────────────────────────────────────────────────────────────────
APP_CONTENT_UNDERSTANDING_ENDPOINT=https://<your-foundry-or-cognitive-services-endpoint>/

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — auth mode.
#   dev  → DefaultAzureCredential (uses `az login`)
#   prod → ManagedIdentityCredential (for Azure-hosted runs)
# ─────────────────────────────────────────────────────────────────────────────
APP_ENV=dev

# ─────────────────────────────────────────────────────────────────────────────
# Model deployments (names in your Foundry project, NOT model family ids).
# ONLY the SEC and Pro services read these — they inject a `models` block
# into their analyzer templates at deploy time. The SOV analyzers bake the
# deployment name directly into the JSON template (see
# demo/sov/reference/analyzer-templates/*.json), so SOV ignores these vars.
# Whichever names you set must exist as deployments in your Foundry project.
# Leave unset to skip injection.
# ─────────────────────────────────────────────────────────────────────────────

# Chat-completion deployment used by SEC (primary) and Pro (fallback).
# Read by:
#   • SEC — sec_service: APP_CU_COMPLETION_DEPLOYMENT → GPT41_MINI_MODEL_DEPLOYMENT → GPT41_MODEL_DEPLOYMENT
#   • Pro — pro_service falls back to this when APP_CU_PRO_COMPLETION_DEPLOYMENT is unset.
APP_CU_COMPLETION_DEPLOYMENT=gpt-4.1-mini

# Embedding deployment — SEC only (sec_service injects it when the template asks for one).
# Resolution order: EMBEDDING_MODEL_DEPLOYMENT → APP_CU_EMBEDDING_DEPLOYMENT
EMBEDDING_MODEL_DEPLOYMENT=text-embedding-3-large

# Pro-mode chat-completion deployment — Pro service only.
# Recommend a GPT-5.2 deployment in a pro-mode region (West US, Sweden Central, Australia East).
# Resolution order (pro_service):
#   APP_CU_PRO_COMPLETION_DEPLOYMENT
#   → APP_CU_COMPLETION_DEPLOYMENT
#   → GPT52_MODEL_DEPLOYMENT → GPT51_MODEL_DEPLOYMENT → GPT41_MODEL_DEPLOYMENT
APP_CU_PRO_COMPLETION_DEPLOYMENT=gpt-5.2

# Named fallbacks consumed by the resolution chains above.
GPT41_MODEL_DEPLOYMENT=gpt-4.1
GPT41_MINI_MODEL_DEPLOYMENT=gpt-4.1-mini
GPT52_MODEL_DEPLOYMENT=gpt-5.2
# GPT51_MODEL_DEPLOYMENT=gpt-5.1

# ─────────────────────────────────────────────────────────────────────────────
# Optional — server & timeouts
# ─────────────────────────────────────────────────────────────────────────────
# Port for the workshop API (standalone_api.py). Default: 8000.
# PORT=8000
# Per-call timeout (seconds) for /analyzer-compare. Default: 300.
# ANALYZER_COMPARE_TIMEOUT_SECONDS=300

# ─────────────────────────────────────────────────────────────────────────────
# Optional — override demo asset roots (default: <repo>/demo/<name>)
# ─────────────────────────────────────────────────────────────────────────────
# SOV_DEMO_ROOT=
# SEC_DEMO_ROOT=
# PRO_DEMO_ROOT=
