# Repo-wide local config. Copy to .env and fill in.
# Used by the workshop API standalone runner and by demo/sov + feedback notebooks.

# Foundry / Cognitive Services endpoint that hosts Content Understanding.
APP_CONTENT_UNDERSTANDING_ENDPOINT=https://<your-foundry-or-cognitive-services-endpoint>/

# Set "dev" to use DefaultAzureCredential (i.e. ``az login``).
APP_ENV=dev

# Optional: timeout (sec) for analyzer compare calls
# ANALYZER_COMPARE_TIMEOUT_SECONDS=300
