# Environment variables — generated by Terraform, copy to .env with real values
# Run: terraform -chdir=infra/non-private output -raw env_local > .env

# Azure credentials (from App Registration)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=

# Foundry
FOUNDRY_ENDPOINT=
FOUNDRY_PROJECT_NAME=
FOUNDRY_RESOURCE_NAME=
AZURE_OPENAI_ENDPOINT=

# AI Search
SEARCH_ENDPOINT=
SEARCH_INDEX_NAME=sec-filings

# Cosmos DB
COSMOSDB_ENDPOINT=

# Storage
STORAGE_ACCOUNT_NAME=
STORAGE_CONTAINER_NAME=sec-filings

# ACL analyst groups
GROUP_OID_AAPL=
GROUP_OID_AMZN=
GROUP_OID_GOOG=
GROUP_OID_MSFT=
GROUP_OID_NVDA=

# Persona service principal
MSFT_SP_CLIENT_ID=
MSFT_SP_CLIENT_SECRET=
MSFT_SP_TENANT_ID=

# Observability
APPINSIGHTS_CONNECTION_STRING=
LOG_ANALYTICS_WORKSPACE_ID=

# Model deployments
GPT_MODEL_DEPLOYMENT=gpt-5.4
GPT41_MODEL_DEPLOYMENT=gpt-4.1
GPT41_MINI_MODEL_DEPLOYMENT=gpt-4.1-mini
EMBEDDING_MODEL_DEPLOYMENT=text-embedding-3-large
CU_STORAGE_CONTAINER_NAME=content-understanding
