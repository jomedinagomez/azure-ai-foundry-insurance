# demo/classifier/.env — copy to .env and fill in.
# Most values are already in the repo-root .env generated by Terraform
# (infra/non-private). This file only needs the classifier-specific bits.

# --- Document Intelligence endpoint ---
# Reuse the existing Foundry AIServices resource. If FOUNDRY_ENDPOINT is the
# *.services.ai.azure.com form, set the *.cognitiveservices.azure.com form here
# (or leave blank and _lib.py will derive it from FOUNDRY_RESOURCE_NAME).
DOCUMENTINTELLIGENCE_ENDPOINT=
# Optional key auth. Leave blank to use DefaultAzureCredential (az login / MSI).
DOCUMENTINTELLIGENCE_KEY=

# --- Storage for training data ---
# Existing account to reuse, or the name to create in notebook 01.
STORAGE_ACCOUNT_NAME=
CLASSIFIER_TRAINING_CONTAINER=classifier-training

# --- Classifier ---
CLASSIFIER_ID=insurance-invoice-claim-v1

# --- Azure context (usually inherited from repo-root .env) ---
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
FOUNDRY_RESOURCE_NAME=
