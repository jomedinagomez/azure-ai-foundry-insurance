# Workshop API local config
# Copy to .env and fill in. Do not commit real values.

# Azure AI Foundry / Cognitive Services endpoint that hosts Content Understanding.
# Example: https://my-foundry.services.ai.azure.com/
APP_CONTENT_UNDERSTANDING_ENDPOINT=https://<your-foundry-or-cognitive-services-endpoint>/

# Set to "dev" to use DefaultAzureCredential (i.e. `az login`).
# Anything else will try ManagedIdentityCredential (for Azure-hosted runs).
APP_ENV=dev

# Pro Mode (Content Understanding pro-mode preview) — chat completion
# deployment used for multi-step reasoning. Falls back to APP_CU_COMPLETION_DEPLOYMENT,
# then GPT52_MODEL_DEPLOYMENT, then GPT51_MODEL_DEPLOYMENT, then GPT41_MODEL_DEPLOYMENT.
# Recommend a GPT-5.2 deployment in a pro-mode-supported region (West US, Sweden Central, Australia East).
# APP_CU_PRO_COMPLETION_DEPLOYMENT=gpt-5.2

# Optional: override timeout for analyzer calls (seconds)
# ANALYZER_COMPARE_TIMEOUT_SECONDS=300
